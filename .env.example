APP_NAME=PodExtract
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

WORK_DIR=/tmp/podextract
SQLITE_PATH=/tmp/podextract/podextract.db

REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_KEY=podextract:jobs

DEDUPE_WINDOW_HOURS=24
MAX_RSS_ITEMS_SCAN=20

STAGE_RETRY_EXTRACT=3
STAGE_RETRY_STT=2
STAGE_RETRY_PUBLISH=2
STAGE_RETRY_BASE_DELAY_SECONDS=1.2

STT_PRIMARY_PROVIDER=minimax
STT_FALLBACK_PROVIDER=elevenlabs

MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_STT_URL=https://api.minimaxi.chat/v1/audio/transcriptions
MINIMAX_STT_MODEL=speech-02-hd

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v1

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=

KB_SEARCH_URL=
KB_SEARCH_API_KEY=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
